<html t:type="layout" xmlns:t="http://tapestry.apache.org/schema/tapestry_5_4.xsd" title="Tasks | EstiMate">
    <link rel="stylesheet" type="text/css" href="/css/tasks.css" />
    <t:security.authenticated>
        <div class="container my-3">
            <div class="row align-items-center">                <!-- Task Status Section -->
                <div class="col-12 col-lg-2 order-lg-2 mb-2 mb-lg-0 text-center">
                    <div class="dropdown">
                        <button class="btn btn-secondary dropdown-toggle" type="button" id="taskStatusDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            ${selectedStatus}
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="taskStatusDropdown">
                            <li>
                                <t:actionlink class="dropdown-item" t:id="filterAll" t:event="filterStatus">
                                    All Tasks
                                </t:actionlink>
                            </li>
                            <li>
                                <t:actionlink class="dropdown-item" t:id="filterInProgress" t:event="filterStatus">
                                    In Progress
                                </t:actionlink>
                            </li>
                            <li>
                                <t:actionlink class="dropdown-item" t:id="filterCompleted" t:event="filterStatus">
                                    Completed
                                </t:actionlink> 
                            </li>
                            <li>
                                <t:actionlink class="dropdown-item" t:id="filterDropped" t:event="filterStatus">
                                    Dropped
                                </t:actionlink>
                            </li>
                            <li>
                                <t:actionlink class="dropdown-item" t:id="filterWillNotComplete" t:event="filterStatus">
                                    Will Not Complete
                                </t:actionlink>
                            </li>
                        </ul>
                    </div> <!-- End of Task Status Section -->
                </div>

                <!-- Date Range Form Section -->
                <div class="col-12 col-lg-7 order-lg-3 mb-2 mb-lg-0 text-center">
                    <t:form t:id="dateForm" class="date-form w-100">
                        <div class="input-group">
                            <!-- Start Date Input -->
                            <t:textField t:id="startDateInput" value="startDate" class="form-control date-input" placeholder="Start Date (MM/dd/yyyy)" style="width: 30%;" />
                            
                            <!-- Finish Date Input -->
                            <t:textField t:id="finishDateInput" value="finishDate" class="form-control date-input" placeholder="Finish Date (MM/dd/yyyy)" style="width: 30%;" />
                            
                            <input type="submit" class="btn btn-primary" value="Search" />
                            <t:actionlink t:id="showAll" class="btn btn-secondary">Show All</t:actionlink>
                        </div>
                    </t:form>
                </div>

                <!-- Create Task Section -->
                <div class="col-12 col-lg-3 order-lg-4 mb-2 mb-lg-0 text-center text-lg-end">
                    <t:pagelink class="btn btn-success create-task" page="tasks/AddTask">Create New Task</t:pagelink>
                </div>
            </div>
        </div>
        <t:if test="noTasks">
            <div class="container d-flex justify-content-center align-items-center noTasks">
                <div class="row">
                    <div class="col text-center">
                        <h2>No tasks to display.</h2>
                    </div>
                </div>
            </div>
        </t:if>
            <t:unless test="noTasks">
                <div class="container">
                    <div class="row" style="margin-top: 2rem;">
                        <div class="col-3" style="padding: 2rem;" t:type="loop" t:source="tasks" t:value="task">
                            <div class="card" style="width: 18rem; border-width: 1rem; background-color: #7c74f6;">
                                <div class="card-body" style="background-color: #ffffff;">
                                    <h4>${task.getName()}</h4>
                                    <h6>Start Date: ${task.getStartDate()}</h6>
                                    <h6>Planned End Date: ${task.getEstEndDate()}</h6>
                                    <h6>Hours Logged: ${task.getTimeTaken()}</h6>
                                    <h6>Status: ${task.getStatus()}</h6>
                                    <div class="row">
                                        <t:pagelink class="btn btn-primary mb-1" page="tasks/EditTask" context="task.pk">Edit Task</t:pagelink>
                                        <button class="btn btn-secondary mb-1" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Log Hours
                                        </button>
                                        <ul class="dropdown-menu text-center" style="min-width: 300px;">
                                            <li class="d-flex flex-column align-items-center">
                                                <div class="d-flex align-items-center">
                                                    <span class="me-2">Hours:</span>
                                                    <t:form t:id="addHourForm" context="task.PK" class="d-flex">
                                                        <t:textfield t:id="hours" class="form-control me-2 text-center" style="width: 100px;" placeholder="Enter hours"/>
                                                        <t:submit value="Add Hours" class="btn btn-primary"/>
                                                    </t:form>
                                                </div>
                                            </li>
                                            <li class="d-flex flex-column align-items-center border-top mt-2">
                                                <span class="mb-2">Hours Quick Add:</span>
                                                <div class="d-flex justify-content-center">
                                                    <t:form t:id="add1HourForm" context="task.PK" class="me-1">
                                                        <input type="submit" value="+1" class="btn btn-outline-secondary btn-sm" />
                                                    </t:form>
                                                    <t:form t:id="add2HourForm" context="task.PK" class="me-1">
                                                        <input type="submit" value="+2" class="btn btn-outline-secondary btn-sm" />
                                                    </t:form>
                                                    <t:form t:id="add3HourForm" context="task.PK" class="me-1">
                                                        <input type="submit" value="+3" class="btn btn-outline-secondary btn-sm" />
                                                    </t:form>
                                                    <t:form t:id="add5HourForm" context="task.PK" class="me-1">
                                                        <input type="submit" value="+5" class="btn btn-outline-secondary btn-sm" />
                                                    </t:form>
                                                    <t:form t:id="add10HourForm" context="task.PK">
                                                        <input type="submit" value="+10" class="btn btn-outline-secondary btn-sm" />
                                                    </t:form>
                                                </div>
                                            </li>
                                        </ul>
                                        <button class="btn btn-success mb-1" type="button" data-bs-toggle="dropdown" aria-expanded="false">Update Status</button>
                                        <ul class="dropdown-menu">
                                            <li class="d-flex justify-content-center">
                                                <t:actionlink t:id="complete" aria-expanded="false" context="task.PK" class="btn btn-secondary mb-1">Completed</t:actionlink>
                                            </li>
                                            <li class="d-flex justify-content-center">
                                                <t:actionlink t:id="drop" aria-expanded="false" context="task.PK" class="btn btn-secondary mb-1">Dropped</t:actionlink>
                                            </li>
                                            <li class="d-flex justify-content-center">
                                                <t:actionlink t:id="willNotComplete" aria-expanded="false" context="task.PK" class="btn btn-secondary mb-1">Will Not Complete</t:actionlink>
                                            </li>
                                            <li class="d-flex justify-content-center">
                                                <t:actionlink t:id="inProgress" aria-expanded="false" context="task.PK" class="btn btn-secondary">In Progress</t:actionlink>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t:unless>
    </t:security.authenticated>
    <t:security.notauthenticated>
        <div class="container d-flex justify-content-center align-items-center loginMessage">
            <div class="row">
                <div class="col text-center">
                    <h2>You need to log in to view this.</h2>
                </div>
            </div>
        </div>
    </t:security.notauthenticated>
</html>
